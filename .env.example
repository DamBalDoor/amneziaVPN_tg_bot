TELEGRAM_BOT_TOKEN=ваш_токен_бота
TELEGRAM_ADMIN_CHAT_ID=123456789

# Интервал проверки в миллисекундах (например, 60000 = 1 минута)
VPN_CHECK_INTERVAL_MS=60000

# Команда healthcheck'а VPN (если задана, systemd не используется)
# Например, выполнить curl из контейнера Amnezia:
# VPN_HEALTHCHECK_CMD=docker exec amnezia-vpn-container curl -sSf https://ifconfig.me
VPN_HEALTHCHECK_CMD=

# Команда перезапуска VPN (для /restart_vpn)
# Для Docker-примера с двумя контейнерами:
# VPN_RESTART_CMD=bash -lc "docker restart amnezia-awg amnezia-openvpn"
VPN_RESTART_CMD=

# Минимальный интервал между перезапусками VPN (секунды)
VPN_RESTART_COOLDOWN_SEC=60

# Путь к лог-файлу (по умолчанию logs/bot.log)
# LOG_FILE_PATH=/var/log/amnezia-vpn-bot.log

# Сколько строк показывать в /logs_tail
LOG_TAIL_LINES=100

